{
  "name": "hp-backend",
  "version": "1.0.0",
  "main": "src/index.js",
  "type": "module",
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "scripts": {
    "dev":         "nodemon",
    "start":       "node src/index.js",
    "postinstall": "prisma generate --schema=src/prisma/schema.prisma",
    "build":       "prisma generate --schema=src/prisma/schema.prisma && prisma db push --schema=src/prisma/schema.prisma && node src/prisma/seed.js",
    "db:migrate":  "npx prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:push":     "npx prisma db push --schema=src/prisma/schema.prisma",
    "db:seed":     "node src/prisma/seed.js",
    "db:studio":   "npx prisma studio --schema=src/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=src/prisma/schema.prisma",
    "db:reset":    "npx prisma migrate reset --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.12",
    "winston": "^3.12.0",
    "xlsx": "^0.18.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
