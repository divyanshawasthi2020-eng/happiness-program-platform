# ─── DATABASE ────────────────────────────────────────────────────────────────
# Option 1: Local PostgreSQL
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/happiness_program"
# Option 2: Supabase (free tier)
# DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

# ─── APP ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── REDIS (optional — for job queues) ───────────────────────────────────────
# If not available, campaigns run synchronously
REDIS_URL=redis://localhost:6379

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────────
# Option 1: Gmail (free — needs App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_16_chars
SMTP_FROM="Happiness Program <your.email@gmail.com>"

# Option 2: Brevo / Sendinblue (free 300 emails/day)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your_brevo_login
# SMTP_PASS=your_brevo_smtp_key

# ─── WHATSAPP ────────────────────────────────────────────────────────────────
# Option 1: wa.me links (free, no API needed) — default
WA_MODE=walink

# Option 2: WA-JS (free, open source, requires WhatsApp scan)
# WA_MODE=wajs
# WAJS_PORT=3002

# Option 3: Interakt (paid ₹999/mo)
# WA_MODE=interakt
# INTERAKT_API_KEY=your_key

# ─── CANVA ───────────────────────────────────────────────────────────────────
# Get from https://www.canva.com/developers (free)
CANVA_CLIENT_ID=your_canva_client_id
CANVA_CLIENT_SECRET=your_canva_client_secret

# ─── UPLOAD ──────────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./uploads
